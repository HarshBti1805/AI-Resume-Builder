<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{fullName}} — Resume</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: "{{fontFamily}}", "Times New Roman", serif;
    font-size: {{fontSize}}pt;
    color: #1a1a1a;
    background: #fff;
    {{#if (eq marginSize "compact")}}padding: 24px 36px;{{else}}{{#if (eq marginSize "wide")}}padding: 48px 60px;{{else}}padding: 36px 48px;{{/if}}{{/if}}
    line-height: {{lineSpacing}};
  }

  /* ── Header ── */
  .header { text-align: center; margin-bottom: 18px; padding-bottom: 12px; border-bottom: 2px solid {{accentColor}}; }
  .header h1 { font-size: {{headingSize}}pt; font-weight: bold; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }
  .contact-line { font-size: 9pt; color: #444; display: flex; justify-content: center; flex-wrap: wrap; gap: 4px 14px; }
  .contact-line a { color: #444; text-decoration: none; }

  /* ── Section ── */
  .section { margin-bottom: 14px; }
  .section-title {
    font-size: {{headingSize}}pt;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    {{#if (eq sectionDivider "none")}}border-bottom: none;{{else}}{{#if (eq sectionDivider "double")}}border-bottom: 3px double {{accentColor}};{{else}}{{#if (eq sectionDivider "dotted")}}border-bottom: 1px dotted {{accentColor}};{{else}}border-bottom: 1px solid {{accentColor}};{{/if}}{{/if}}{{/if}}
    padding-bottom: 3px;
    margin-bottom: 8px;
    color: {{accentColor}};
  }

  /* ── Summary ── */
  .summary p { font-style: italic; color: #333; }

  /* ── Education ── */
  .edu-row, .exp-row { margin-bottom: 8px; }
  .row-header { display: flex; justify-content: space-between; align-items: baseline; }
  .row-title { font-weight: bold; font-size: 10.5pt; }
  .row-date { font-size: 9pt; color: #555; white-space: nowrap; }
  .row-sub { font-size: 9.5pt; color: #444; margin-top: 1px; }
  .row-desc { font-size: 9.5pt; margin-top: 3px; color: #333; }

  /* ── Skills ── */
  .skills-list { font-size: 9.5pt; color: #333; }

  /* ── Projects ── */
  .project-item { margin-bottom: 8px; }
  .project-title { font-weight: bold; }
  .project-tech { font-size: 8.5pt; color: #555; }
  .project-links { font-size: 8.5pt; color: #555; margin-top: 1px; }
  .project-links a { color: #555; }

  /* ── Achievements ── */
  .achievement-item { margin-bottom: 4px; }
  .achievement-title { font-weight: bold; }

  /* ── Hobbies ── */
  .hobbies { font-size: 9.5pt; color: #444; }

  /* ── Photo (optional) ── */
  .photo { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; display: block; margin: 0 auto 8px; }
</style>
</head>
<body>

<!-- ── HEADER ────────────────────────────── -->
<div class="header">
  {{#ifVal photoUrl}}
    <img class="photo" src="{{photoUrl}}" alt="Profile photo" />
  {{/ifVal}}
  <h1>{{fullName}}</h1>
  <div class="contact-line">
    {{#ifVal contactEmail}}<span>{{contactEmail}}</span>{{/ifVal}}
    {{#ifVal phone}}<span>{{phone}}</span>{{/ifVal}}
    {{#ifVal city}}<span>{{city}}{{#ifVal state}}, {{state}}{{/ifVal}}</span>{{/ifVal}}
    {{#ifVal linkedin}}<a href="{{linkedin}}" target="_blank">LinkedIn</a>{{/ifVal}}
    {{#ifVal github}}<a href="{{github}}" target="_blank">GitHub</a>{{/ifVal}}
    {{#ifVal portfolio}}<a href="{{portfolio}}" target="_blank">Portfolio</a>{{/ifVal}}
  </div>
</div>

<!-- ── SECTIONS (ordered by sectionOrder) ───────────────────────────── -->
{{#each sectionOrder}}
{{#if (eq this "summary")}}
{{#ifVal ../summary}}
<div class="section summary">
  <div class="section-title">{{sectionTitle this}}</div>
  <p>{{../summary}}</p>
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "education")}}
{{#ifVal ../university}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="edu-row">
    <div class="row-header">
      <span class="row-title">{{../university}}</span>
      <span class="row-date">{{../batchStart}} – {{../batchEnd}}</span>
    </div>
    <div class="row-sub">
      {{../stream}}{{#ifVal ../branch}} — {{../branch}}{{/ifVal}}
      {{#ifVal ../cgpa}} &nbsp;|&nbsp; CGPA: {{../cgpa}}{{/ifVal}}
    </div>
  </div>
  {{#if ../showMarks12th}}
    {{#ifVal ../marks12th}}
    <div class="edu-row">
      <div class="row-header">
        <span class="row-title">12th Grade{{#ifVal ../board12th}} — {{../board12th}}{{/ifVal}}{{#ifVal ../schoolName12th}} ({{../schoolName12th}}){{/ifVal}}</span>
        <span class="row-date">{{../marks12th}}%</span>
      </div>
    </div>
    {{/ifVal}}
  {{/if}}
  {{#if ../showMarks10th}}
    {{#ifVal ../marks10th}}
    <div class="edu-row">
      <div class="row-header">
        <span class="row-title">10th Grade{{#ifVal ../board10th}} — {{../board10th}}{{/ifVal}}{{#ifVal ../schoolName10th}} ({{../schoolName10th}}){{/ifVal}}</span>
        <span class="row-date">{{../marks10th}}%</span>
      </div>
    </div>
    {{/ifVal}}
  {{/if}}
  {{#if ../showCoursework}}
    {{#ifNotEmpty ../coursework}}
    <div class="row-sub" style="margin-top:4px;">
      <strong>Relevant Coursework:</strong> {{join ../coursework ", "}}
    </div>
    {{/ifNotEmpty}}
  {{/if}}
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "skills")}}
{{#ifNotEmpty ../skillCategories}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../skillCategories}}
  <div class="skills-list"><strong>{{name}}:</strong> {{join skills ", "}}</div>
  {{/each}}
</div>
{{else}}
{{#ifNotEmpty ../skills}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="skills-list">{{join ../skills " • "}}</div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "experience")}}
{{#ifNotEmpty ../internships}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../internships}}
  <div class="exp-row">
    <div class="row-header">
      <span class="row-title">{{role}} — {{company}}</span>
      <span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
    </div>
    {{#ifNotEmpty bullets}}
    <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li>{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "projects")}}
{{#ifNotEmpty ../projects}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../projects}}
  <div class="project-item">
    <div class="row-header">
      <span class="project-title">{{title}}</span>
      {{#ifVal startDate}}<span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>{{/ifVal}}
    </div>
    {{#ifNotEmpty techStack}}<div class="project-tech">{{join techStack " • "}}</div>{{/ifNotEmpty}}
    {{#ifNotEmpty bullets}}
    <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li>{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
    {{#ifVal liveUrl}}
    <div class="project-links">
      <a href="{{liveUrl}}">Live</a>
      {{#ifVal repoUrl}}&nbsp;|&nbsp;<a href="{{repoUrl}}">Repository</a>{{/ifVal}}
    </div>
    {{/ifVal}}
    {{#ifVal repoUrl}}
      {{#unless liveUrl}}
      <div class="project-links">
        <a href="{{repoUrl}}">Repository</a>
      </div>
      {{/unless}}
    {{/ifVal}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "achievements")}}
{{#ifNotEmpty ../achievements}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../achievements}}
  <div class="achievement-item">
    <span class="achievement-title">{{title}}</span>
    {{#ifVal description}} — {{description}}{{/ifVal}}
    {{#ifVal link}} <a href="{{link}}" style="font-size:8.5pt;color:#555;">[Link]</a>{{/ifVal}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "hobbies")}}
{{#ifNotEmpty ../hobbyItems}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="hobbies">
    {{#each ../hobbyItems}}{{#if @index}} • {{/if}}{{name}}{{#ifVal description}} ({{description}}){{/ifVal}}{{/each}}
  </div>
</div>
{{else}}
{{#ifNotEmpty ../hobbies}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="hobbies">{{join ../hobbies " • "}}</div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#with (customSectionById this)}}
<div class="section">
  <div class="section-title">{{title}}</div>
  <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
    {{#each items}}<li>{{text}}</li>{{/each}}
  </ul>
</div>
{{/with}}
{{/each}}

</body>
</html>
