<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>{{fullName}} — Resume</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: "{{fontFamily}}", Arial, sans-serif;
    font-size: {{fontSize}}pt;
    color: #222;
    background: #fff;
    padding: 0;
    line-height: {{lineSpacing}};
  }

  /* ── Top accent bar ── */
  .accent-bar { background: {{accentColor}}; height: 6px; }

  .page { {{#if (eq marginSize "compact")}}padding: 24px 36px;{{else}}{{#if (eq marginSize "wide")}}padding: 48px 60px;{{else}}padding: 32px 48px;{{/if}}{{/if}} }

  /* ── Header ── */
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 22px; }
  .header-left h1 { font-size: {{headingSize}}pt; font-weight: 700; color: #111; margin-bottom: 2px; }
  .header-left .subtitle { font-size: 11pt; color: {{accentColor}}; font-weight: 600; }
  .header-right { text-align: right; font-size: 9pt; color: #555; line-height: 1.7; }
  .header-right a { color: {{accentColor}}; text-decoration: none; }

  /* ── Photo ── */
  .photo { width: 72px; height: 72px; border-radius: 8px; object-fit: cover; margin-left: 20px; }

  /* ── Section ── */
  .section { margin-bottom: 16px; }
  .section-title {
    font-size: {{headingSize}}pt;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: {{accentColor}};
    {{#if (eq sectionDivider "none")}}border-bottom: none;{{else}}{{#if (eq sectionDivider "double")}}border-bottom: 3px double {{accentColor}};{{else}}{{#if (eq sectionDivider "dotted")}}border-bottom: 2px dotted {{accentColor}};{{else}}border-bottom: 2px solid {{accentColor}};{{/if}}{{/if}}{{/if}}
    padding-bottom: 3px;
    margin-bottom: 10px;
  }

  /* ── Row ── */
  .row { margin-bottom: 9px; }
  .row-header { display: flex; justify-content: space-between; align-items: baseline; }
  .row-title { font-weight: 700; font-size: 10pt; }
  .row-date { font-size: 8.5pt; color: #666; white-space: nowrap; }
  .row-sub { font-size: 9pt; color: #555; margin-top: 1px; }
  .row-desc { font-size: 9pt; color: #444; margin-top: 3px; }

  /* ── Skills chips ── */
  .chips { display: flex; flex-wrap: wrap; gap: 5px; }
  .chip {
    background: #eff6ff;
    color: #1d4ed8;
    border: 1px solid #bfdbfe;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 8.5pt;
    font-weight: 500;
  }

  /* ── Project ── */
  .project-tech { font-size: 8.5pt; color: #666; margin-top: 1px; }
  .project-links { font-size: 8.5pt; margin-top: 2px; }
  .project-links a { color: {{accentColor}}; text-decoration: none; margin-right: 10px; }
  .project-subtitle { font-style: italic; font-weight: 500; color: #555; }

  /* ── Achievements ── */
  .ach-item { display: flex; gap: 6px; margin-bottom: 4px; font-size: 9.5pt; }
  .ach-dot { color: {{accentColor}}; font-weight: bold; }

  /* ── Hobbies ── */
  .hobbies { font-size: 9.5pt; color: #555; }
</style>
</head>
<body>

<div class="accent-bar"></div>
<div class="page">

<!-- ── HEADER ── -->
<div class="header">
  <div class="header-left">
    <h1>{{fullName}}</h1>
    {{#ifVal stream}}<div class="subtitle">{{stream}}{{#ifVal branch}} — {{branch}}{{/ifVal}}</div>{{/ifVal}}
  </div>
  <div style="display:flex; align-items:flex-start;">
    <div class="header-right">
      {{#ifVal contactEmail}}<div>{{contactEmail}}</div>{{/ifVal}}
      {{#ifVal phone}}<div>{{phone}}</div>{{/ifVal}}
      {{#ifVal city}}<div>{{city}}{{#ifVal state}}, {{state}}{{/ifVal}}</div>{{/ifVal}}
      {{#ifVal linkedin}}<div><a href="{{linkedin}}">LinkedIn</a></div>{{/ifVal}}
      {{#ifVal github}}<div><a href="{{github}}">GitHub</a></div>{{/ifVal}}
      {{#ifVal portfolio}}<div><a href="{{portfolio}}">Portfolio</a></div>{{/ifVal}}
    </div>
    {{#ifVal photoUrl}}<img class="photo" src="{{photoUrl}}" alt="" />{{/ifVal}}
  </div>
</div>

<!-- ── SECTIONS (ordered by sectionOrder) ── -->
{{#each sectionOrder}}
{{#if (eq this "summary")}}
{{#ifVal ../summary}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row-desc">{{../summary}}</div>
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "skills")}}
{{#ifNotEmpty ../skillCategories}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../skillCategories}}
  <div style="margin-bottom:6px;">
    <span style="font-weight:700;font-size:9pt;color:#1d4ed8;">{{name}}:</span>
    <span class="chips" style="display:inline-flex;gap:4px;margin-left:4px;">
      {{#each skills}}<span class="chip">{{this}}</span>{{/each}}
    </span>
  </div>
  {{/each}}
</div>
{{else}}
{{#ifNotEmpty ../skills}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="chips">
    {{#each ../skills}}<span class="chip">{{this}}</span>{{/each}}
  </div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "education")}}
{{#ifVal ../university}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{../university}}</span>
      <span class="row-date">{{../batchStart}} – {{../batchEnd}}</span>
    </div>
    <div class="row-sub">
      {{../stream}}{{#ifVal ../branch}} · {{../branch}}{{/ifVal}}
      {{#ifVal ../cgpa}} · CGPA {{../cgpa}}{{/ifVal}}
    </div>
  </div>
  {{#unless (eq ../showMarks12th false)}}
    {{#ifVal ../marks12th}}
    <div class="row">
      <div class="row-header">
        <span class="row-title">12th{{#ifVal ../board12th}} · {{../board12th}}{{/ifVal}}{{#ifVal ../schoolName12th}} · {{../schoolName12th}}{{/ifVal}}</span>
        <span class="row-date">{{../marks12th}}%</span>
      </div>
    </div>
    {{/ifVal}}
  {{/unless}}
  {{#unless (eq ../showMarks10th false)}}
    {{#ifVal ../marks10th}}
    <div class="row">
      <div class="row-header">
        <span class="row-title">10th{{#ifVal ../board10th}} · {{../board10th}}{{/ifVal}}{{#ifVal ../schoolName10th}} · {{../schoolName10th}}{{/ifVal}}</span>
        <span class="row-date">{{../marks10th}}%</span>
      </div>
    </div>
    {{/ifVal}}
  {{/unless}}
  {{#unless (eq ../showCoursework false)}}
    {{#ifNotEmpty ../coursework}}<div class="row-sub" style="margin-top:4px;"><strong>Coursework:</strong> {{join ../coursework ", "}}</div>{{/ifNotEmpty}}
  {{/unless}}
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "experience")}}
{{#ifNotEmpty ../internships}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../internships}}
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{role}} · {{company}}</span>
      <span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
    </div>
    {{#ifNotEmpty bullets}}
    <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li>{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "projects")}}
{{#ifNotEmpty ../projects}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../projects}}
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{title}}{{#ifVal subtitle}} - <span class="project-subtitle">{{subtitle}}</span>{{/ifVal}}</span>
      {{#ifVal startDate}}<span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>{{/ifVal}}
    </div>
    {{#ifNotEmpty techStack}}<div class="project-tech">{{join techStack " · "}}</div>{{/ifNotEmpty}}
    {{#ifNotEmpty bullets}}
    <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li>{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
    {{#ifVal liveUrl}}
      <div class="project-links">
        <a href="{{liveUrl}}">🔗 Live</a>
        {{#ifVal repoUrl}}<a href="{{repoUrl}}">⌥ Repo</a>{{/ifVal}}
      </div>
    {{/ifVal}}
    {{#ifVal repoUrl}}
      {{#unless liveUrl}}
      <div class="project-links">
        <a href="{{repoUrl}}">⌥ Repo</a>
      </div>
      {{/unless}}
    {{/ifVal}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "achievements")}}
{{#ifNotEmpty ../achievements}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../achievements}}
  <div class="ach-item">
    <span class="ach-dot">▸</span>
    <span><strong>{{title}}</strong>{{#ifVal description}} — {{description}}{{/ifVal}}{{#ifVal link}} <a href="{{link}}" style="font-size:8pt;">[Link]</a>{{/ifVal}}</span>
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "hobbies")}}
{{#ifNotEmpty ../hobbyItems}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="hobbies">
    {{#each ../hobbyItems}}{{#if @index}} · {{/if}}{{name}}{{#ifVal description}} ({{description}}){{/ifVal}}{{/each}}
  </div>
</div>
{{else}}
{{#ifNotEmpty ../hobbies}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="hobbies">{{join ../hobbies " · "}}</div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#with (customSectionById this)}}
<div class="section">
  <div class="section-title">{{title}}</div>
  <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
    {{#each items}}<li>{{text}}</li>{{/each}}
  </ul>
</div>
{{/with}}
{{/each}}

</div>
</body>
</html>
