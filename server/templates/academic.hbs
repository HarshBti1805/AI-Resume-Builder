<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>{{fullName}} — Curriculum Vitae</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: "{{fontFamily}}", Palatino, serif;
    font-size: {{fontSize}}pt;
    color: #1a1a1a;
    background: #fff;
    {{#if (eq marginSize "compact")}}padding: 28px 40px;{{else}}{{#if (eq marginSize "wide")}}padding: 52px 64px;{{else}}padding: 40px 52px;{{/if}}{{/if}}
    line-height: {{lineSpacing}};
  }

  /* ── Header ── */
  .header { margin-bottom: 20px; }
  h1 { font-size: {{headingSize}}pt; font-weight: bold; margin-bottom: 4px; }
  .tagline { font-size: 10.5pt; color: #555; font-style: italic; margin-bottom: 8px; }
  .contact { font-size: 9pt; color: #444; }
  .contact a { color: #444; text-decoration: none; }
  .contact-sep::before { content: " | "; }

  /* ── Section ── */
  .section { margin-bottom: 16px; }
  .section-title {
    font-size: {{headingSize}}pt;
    font-variant: small-caps;
    font-weight: bold;
    {{#if (eq sectionDivider "none")}}border-bottom: none;{{else}}{{#if (eq sectionDivider "double")}}border-bottom: 3px double {{accentColor}};{{else}}{{#if (eq sectionDivider "dotted")}}border-bottom: 1px dotted {{accentColor}};{{else}}border-bottom: 1.5px solid {{accentColor}};{{/if}}{{/if}}{{/if}}
    padding-bottom: 2px;
    margin-bottom: 10px;
    letter-spacing: 0.5px;
    color: {{accentColor}};
  }

  /* ── Education rows ── */
  .edu-row { margin-bottom: 4px; }
  .edu-inst { font-weight: bold; font-size: 10.5pt; }
  .edu-degree { font-size: 10pt; font-style: italic; color: #333; }
  .edu-meta { font-size: 9pt; color: #555; margin-top: 1px; }
  .edu-year { float: right; font-size: 9.5pt; color: #555; }

  /* ── General row ── */
  .row { margin-bottom: 9px; }
  .row-header { display: flex; justify-content: space-between; }
  .row-title { font-weight: bold; }
  .row-date { font-size: 9pt; color: #666; }
  .row-sub { font-size: 9.5pt; color: #555; font-style: italic; margin-top: 1px; }
  .row-desc { font-size: 9.5pt; color: #333; margin-top: 3px; }
  .proj-links { font-size: 9pt; color: #555; margin-top: 3px; }
  .proj-links a { color: #555; text-decoration: none; }

  /* ── Skills ── */
  .skills-row { margin-bottom: 5px; font-size: 9.5pt; }
  .skill-cat { font-weight: bold; }

  /* ── Achievements ── */
  .ach { margin-bottom: 5px; font-size: 9.5pt; }
  .ach::before { content: "◆ "; font-size: 7pt; }

  /* ── Hobbies ── */
  .hobbies { font-size: 9.5pt; color: #444; }

  /* ── Photo ── */
  .header-wrap { display: flex; justify-content: space-between; }
  .photo { width: 72px; height: 72px; border-radius: 50%; object-fit: cover; border: 1px solid #ccc; }
</style>
</head>
<body>

<!-- ── HEADER ── -->
<div class="header-wrap">
  <div class="header">
    <h1>{{fullName}}</h1>
    {{#ifVal stream}}<div class="tagline">{{stream}}{{#ifVal branch}} — {{branch}}{{/ifVal}}</div>{{/ifVal}}
    <div class="contact">
      {{#ifVal contactEmail}}<span>{{contactEmail}}</span>{{/ifVal}}
      {{#ifVal phone}}<span class="contact-sep">{{phone}}</span>{{/ifVal}}
      {{#ifVal city}}<span class="contact-sep">{{city}}{{#ifVal state}}, {{state}}{{/ifVal}}</span>{{/ifVal}}
      {{#ifVal linkedin}}<span class="contact-sep"><a href="{{linkedin}}">LinkedIn</a></span>{{/ifVal}}
      {{#ifVal github}}<span class="contact-sep"><a href="{{github}}">GitHub</a></span>{{/ifVal}}
      {{#ifVal portfolio}}<span class="contact-sep"><a href="{{portfolio}}">Portfolio</a></span>{{/ifVal}}
    </div>
  </div>
  {{#ifVal photoUrl}}<img class="photo" src="{{photoUrl}}" alt="" />{{/ifVal}}
</div>

<!-- ── SECTIONS (ordered by sectionOrder) ── -->
{{#each sectionOrder}}
{{#if (eq this "summary")}}
{{#ifVal ../summary}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row-desc">{{../summary}}</div>
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "education")}}
{{#ifVal ../university}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="edu-row">
    <div class="edu-inst">{{../university}} <span class="edu-year">{{../batchStart}} – {{../batchEnd}}</span></div>
    <div class="edu-degree">{{../stream}}{{#ifVal ../branch}}, {{../branch}}{{/ifVal}}</div>
    {{#ifVal ../cgpa}}<div class="edu-meta">CGPA: {{../cgpa}}</div>{{/ifVal}}
  </div>
  {{#unless (eq ../showMarks12th false)}}
    {{#ifVal ../marks12th}}
    <div class="edu-row">
      <div class="edu-inst">Senior Secondary (12th) <span class="edu-year">{{../marks12th}}%</span></div>
      <div class="edu-degree">
        {{#ifVal ../board12th}}{{../board12th}}{{/ifVal}}
        {{#ifVal ../schoolName12th}}
          {{#ifVal ../board12th}} · {{/ifVal}}{{../schoolName12th}}
        {{/ifVal}}
      </div>
    </div>
    {{/ifVal}}
  {{/unless}}
  {{#unless (eq ../showMarks10th false)}}
    {{#ifVal ../marks10th}}
    <div class="edu-row">
      <div class="edu-inst">Secondary (10th) <span class="edu-year">{{../marks10th}}%</span></div>
      <div class="edu-degree">
        {{#ifVal ../board10th}}{{../board10th}}{{/ifVal}}
        {{#ifVal ../schoolName10th}}
          {{#ifVal ../board10th}} · {{/ifVal}}{{../schoolName10th}}
        {{/ifVal}}
      </div>
    </div>
    {{/ifVal}}
    {{/unless}}
  {{#unless (eq ../showCoursework false)}}{{#ifNotEmpty ../coursework}}
  <div class="edu-meta" style="margin-top:3px;">Relevant Coursework: {{join ../coursework ", "}}</div>
  {{/ifNotEmpty}}{{/unless}}
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "experience")}}
{{#ifNotEmpty ../internships}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../internships}}
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{role}}</span>
      <span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
    </div>
    <div class="row-sub">{{company}}</div>
    {{#ifNotEmpty bullets}}
    <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li>{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
    {{#ifVal liveUrl}}
    <div class="proj-links">
      <a href="{{liveUrl}}">Live</a>
      {{#ifVal repoUrl}} &nbsp;|&nbsp; <a href="{{repoUrl}}">Repo</a>{{/ifVal}}
    </div>
    {{/ifVal}}
    {{#ifVal repoUrl}}
      {{#unless liveUrl}}
      <div class="proj-links">
        <a href="{{repoUrl}}">Repo</a>
      </div>
      {{/unless}}
    {{/ifVal}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "projects")}}
{{#ifNotEmpty ../projects}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../projects}}
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{title}}</span>
      {{#ifVal startDate}}<span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>{{/ifVal}}
    </div>
    {{#ifNotEmpty techStack}}<div class="row-sub">{{join techStack ", "}}</div>{{/ifNotEmpty}}
    {{#ifNotEmpty bullets}}
    <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li>{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "skills")}}
{{#ifNotEmpty ../skillCategories}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../skillCategories}}
  <div class="skills-row"><span class="skill-cat">{{name}}:</span> {{join skills ", "}}</div>
  {{/each}}
</div>
{{else}}
{{#ifNotEmpty ../skills}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row-desc">{{join ../skills " · "}}</div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "achievements")}}
{{#ifNotEmpty ../achievements}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../achievements}}
  <div class="ach"><strong>{{title}}</strong>{{#ifVal description}} — {{description}}{{/ifVal}}{{#ifVal link}} <a href="{{link}}" style="font-size:8pt;color:#444;">[Link]</a>{{/ifVal}}</div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "hobbies")}}
{{#ifNotEmpty ../hobbyItems}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="hobbies">
    {{#each ../hobbyItems}}{{#if @index}} · {{/if}}{{name}}{{#ifVal description}} ({{description}}){{/ifVal}}{{/each}}
  </div>
</div>
{{else}}
{{#ifNotEmpty ../hobbies}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="hobbies">{{join ../hobbies " · "}}</div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#with (customSectionById this)}}
<div class="section">
  <div class="section-title">{{title}}</div>
  <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
    {{#each items}}<li>{{text}}</li>{{/each}}
  </ul>
</div>
{{/with}}
{{/each}}

</body>
</html>
