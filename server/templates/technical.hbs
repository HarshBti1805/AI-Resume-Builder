<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>{{fullName}} — Resume</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: "{{fontFamily}}", Arial, sans-serif;
    font-size: {{fontSize}}pt;
    color: #1f2937;
    background: #fff;
    {{#if (eq marginSize "compact")}}padding: 20px 36px;{{else}}{{#if (eq marginSize "wide")}}padding: 40px 56px;{{else}}padding: 28px 44px;{{/if}}{{/if}}
    line-height: {{lineSpacing}};
  }

  /* ── Header ── */
  .header { border-left: 4px solid {{accentColor}}; padding-left: 14px; margin-bottom: 20px; }
  h1 { font-size: {{headingSize}}pt; font-weight: 700; color: #0f172a; margin-bottom: 2px; }
  .header-sub { font-size: 10pt; color: {{accentColor}}; font-weight: 600; margin-bottom: 6px; }
  .contact { font-size: 8.5pt; color: #6b7280; display: flex; flex-wrap: wrap; gap: 0 16px; }
  .contact a { color: {{accentColor}}; text-decoration: none; }

  /* ── Section ── */
  .section { margin-bottom: 15px; }
  .section-title {
    font-size: {{headingSize}}pt;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: {{accentColor}};
    margin-bottom: 8px;
    padding-bottom: 3px;
    {{#if (eq sectionDivider "none")}}border-bottom: none;{{else}}{{#if (eq sectionDivider "double")}}border-bottom: 3px double {{accentColor}};{{else}}{{#if (eq sectionDivider "dotted")}}border-bottom: 2px dotted {{accentColor}};{{else}}border-bottom: 1.5px solid {{accentColor}};{{/if}}{{/if}}{{/if}}
  }

  /* ── Skills – grouped by category ── */
  .skills-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4px 20px; }
  .skill-group { font-size: 9pt; }
  .skill-group-label { font-weight: 700; color: #374151; }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 3px; }
  .skill-tag {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #166534;
    border-radius: 3px;
    padding: 1px 7px;
    font-size: 8pt;
    font-weight: 500;
  }

  /* ── Projects (prominent) ── */
  .project-card {
    border: 1px solid #e5e7eb;
    border-left: 3px solid {{accentColor}};
    border-radius: 4px;
    padding: 8px 12px;
    margin-bottom: 8px;
  }
  .proj-header { display: flex; justify-content: space-between; align-items: baseline; }
  .proj-title { font-weight: 700; font-size: 10pt; color: #0f172a; }
  .proj-date { font-size: 8.5pt; color: #9ca3af; }
  .proj-tech { margin-top: 3px; display: flex; flex-wrap: wrap; gap: 3px; }
  .proj-tech-tag {
    background: #f1f5f9;
    color: #475569;
    border-radius: 3px;
    padding: 1px 6px;
    font-size: 8pt;
    font-family: "Courier New", monospace;
  }
  .proj-desc { font-size: 9pt; color: #4b5563; margin-top: 4px; }
  .proj-links { font-size: 8pt; color: #6b7280; margin-top: 4px; }
  .proj-links a { color: {{accentColor}}; text-decoration: none; margin-right: 10px; }

  /* ── Row ── */
  .row { margin-bottom: 9px; }
  .row-header { display: flex; justify-content: space-between; }
  .row-title { font-weight: 700; }
  .row-date { font-size: 8.5pt; color: #9ca3af; }
  .row-sub { font-size: 9pt; color: #6b7280; margin-top: 1px; }
  .row-desc { font-size: 9pt; color: #4b5563; margin-top: 3px; }

  /* ── Achievements ── */
  .ach-item { margin-bottom: 4px; font-size: 9.5pt; }
  .ach-badge { display: inline-block; background: {{accentColor}}; color: #fff; font-size: 7.5pt; font-weight: 700; border-radius: 3px; padding: 1px 5px; margin-right: 5px; text-transform: uppercase; }

  /* ── Photo ── */
  .header-wrap { display: flex; justify-content: space-between; align-items: flex-start; }
  .photo { width: 68px; height: 68px; border-radius: 6px; object-fit: cover; }
</style>
</head>
<body>

<!-- ── HEADER ── -->
<div class="header-wrap">
  <div class="header">
    <h1>{{fullName}}</h1>
    {{#ifVal stream}}<div class="header-sub">{{stream}}{{#ifVal branch}} · {{branch}}{{/ifVal}}</div>{{/ifVal}}
    <div class="contact">
      {{#ifVal contactEmail}}<span>{{contactEmail}}</span>{{/ifVal}}
      {{#ifVal phone}}<span>{{phone}}</span>{{/ifVal}}
      {{#ifVal city}}<span>{{city}}{{#ifVal state}}, {{state}}{{/ifVal}}</span>{{/ifVal}}
      {{#ifVal github}}<span><a href="{{github}}">GitHub</a></span>{{/ifVal}}
      {{#ifVal linkedin}}<span><a href="{{linkedin}}">LinkedIn</a></span>{{/ifVal}}
      {{#ifVal portfolio}}<span><a href="{{portfolio}}">Portfolio</a></span>{{/ifVal}}
    </div>
  </div>
  {{#ifVal photoUrl}}<img class="photo" src="{{photoUrl}}" alt="" />{{/ifVal}}
</div>

<!-- ── SECTIONS (ordered by sectionOrder) ── -->
{{#each sectionOrder}}
{{#if (eq this "summary")}}
{{#ifVal ../summary}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row-desc">{{../summary}}</div>
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "skills")}}
{{#ifNotEmpty ../skillCategories}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="skills-grid">
    {{#each ../skillCategories}}
    <div class="skill-group">
      <span class="skill-group-label">{{name}}</span>
      <div class="skill-tags">
        {{#each skills}}<span class="skill-tag">{{this}}</span>{{/each}}
      </div>
    </div>
    {{/each}}
  </div>
</div>
{{else}}
{{#ifNotEmpty ../skills}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="skill-tags">
    {{#each ../skills}}<span class="skill-tag">{{this}}</span>{{/each}}
  </div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "projects")}}
{{#ifNotEmpty ../projects}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../projects}}
  <div class="project-card">
    <div class="proj-header">
      <span class="proj-title">{{title}}</span>
      {{#ifVal startDate}}<span class="proj-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>{{/ifVal}}
    </div>
    {{#ifNotEmpty techStack}}
    <div class="proj-tech">
      {{#each techStack}}<span class="proj-tech-tag">{{this}}</span>{{/each}}
    </div>
    {{/ifNotEmpty}}
    {{#ifNotEmpty bullets}}
    <ul style="padding-left:18px;margin-top:4px;">
      {{#each bullets}}<li class="proj-desc">{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="proj-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
    {{#ifVal liveUrl}}
    <div class="proj-links">
      <a href="{{liveUrl}}">⬡ Live Demo</a>
      {{#ifVal repoUrl}}<a href="{{repoUrl}}">⌬ Source Code</a>{{/ifVal}}
    </div>
    {{/ifVal}}
    {{#ifVal repoUrl}}
      {{#unless liveUrl}}
      <div class="proj-links">
        <a href="{{repoUrl}}">⌬ Source Code</a>
      </div>
      {{/unless}}
    {{/ifVal}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "experience")}}
{{#ifNotEmpty ../internships}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../internships}}
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{role}} · {{company}}</span>
      <span class="row-date">{{fmtDate startDate}} – {{fmtDate endDate}}</span>
    </div>
    {{#ifNotEmpty bullets}}
    <ul style="padding-left:18px;margin-top:3px;">
      {{#each bullets}}<li class="row-desc">{{text}}</li>{{/each}}
    </ul>
    {{else}}
    {{#ifVal description}}<div class="row-desc">{{description}}</div>{{/ifVal}}
    {{/ifNotEmpty}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "education")}}
{{#ifVal ../university}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row">
    <div class="row-header">
      <span class="row-title">{{../university}}</span>
      <span class="row-date">{{../batchStart}} – {{../batchEnd}}</span>
    </div>
    <div class="row-sub">{{../stream}}{{#ifVal ../branch}}, {{../branch}}{{/ifVal}}{{#ifVal ../cgpa}} · CGPA {{../cgpa}}{{/ifVal}}</div>
  </div>
  {{#unless (eq ../showMarks12th false)}}{{#ifVal ../marks12th}}<div class="row"><div class="row-header"><span class="row-title">12th — {{../board12th}}{{#ifVal ../schoolName12th}} ({{../schoolName12th}}){{/ifVal}}</span><span class="row-date">{{../marks12th}}%</span></div></div>{{/ifVal}}{{/unless}}
  {{#unless (eq ../showMarks10th false)}}{{#ifVal ../marks10th}}<div class="row"><div class="row-header"><span class="row-title">10th — {{../board10th}}{{#ifVal ../schoolName10th}} ({{../schoolName10th}}){{/ifVal}}</span><span class="row-date">{{../marks10th}}%</span></div></div>{{/ifVal}}{{/unless}}
  {{#unless (eq ../showCoursework false)}}{{#ifNotEmpty ../coursework}}<div class="row-sub" style="margin-top:4px;">Coursework: {{join ../coursework ", "}}</div>{{/ifNotEmpty}}{{/unless}}
</div>
{{/ifVal}}
{{/if}}

{{#if (eq this "achievements")}}
{{#ifNotEmpty ../achievements}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  {{#each ../achievements}}
  <div class="ach-item">
    <span class="ach-badge">{{type}}</span>
    <strong>{{title}}</strong>{{#ifVal description}} — {{description}}{{/ifVal}}{{#ifVal link}} <a href="{{link}}" style="font-size:8pt;color:#0f766e;">[Link]</a>{{/ifVal}}
  </div>
  {{/each}}
</div>
{{/ifNotEmpty}}
{{/if}}

{{#if (eq this "hobbies")}}
{{#ifNotEmpty ../hobbyItems}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row-desc">
    {{#each ../hobbyItems}}{{#if @index}} · {{/if}}{{name}}{{#ifVal description}} ({{description}}){{/ifVal}}{{/each}}
  </div>
</div>
{{else}}
{{#ifNotEmpty ../hobbies}}
<div class="section">
  <div class="section-title">{{sectionTitle this}}</div>
  <div class="row-desc">{{join ../hobbies " · "}}</div>
</div>
{{/ifNotEmpty}}
{{/ifNotEmpty}}
{{/if}}

{{#with (customSectionById this)}}
<div class="section">
  <div class="section-title">{{title}}</div>
  <ul class="row-desc" style="padding-left:18px;margin-top:3px;">
    {{#each items}}<li>{{text}}</li>{{/each}}
  </ul>
</div>
{{/with}}
{{/each}}

</body>
</html>
